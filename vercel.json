{
  "redirects": [
    {
      "source": "/zh.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/ru.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/blog", "destination": "/api/blog/index" },
    { "source": "/blog/(.*)", "destination": "/api/blog/$1" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" }
  ]
}
